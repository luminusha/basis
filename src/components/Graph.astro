---
interface NodeIn {
  id: string;
  label: string;
  weight: number;
}
interface EdgeIn {
  source: string;
  target: string;
  weight?: number;
  sharedTags?: string[];
}

interface Props {
  nodes: NodeIn[];
  edges: EdgeIn[];
  id?: string;
  height?: number;
  emptyMessage?: string;
  /** How aggressively to truncate displayed labels. Long titles will be ellipsised. */
  labelMaxChars?: number;
}

const {
  nodes,
  edges,
  id = 'graph',
  height = 460,
  emptyMessage = 'Not enough data yet, the graph will fill in as more sessions are added.',
  labelMaxChars = 28,
} = Astro.props;

function ellipsise(s: string, n: number): string {
  if (s.length <= n) return s;
  return s.slice(0, n - 1).trimEnd() + '…';
}

const isEmpty = nodes.length === 0;
const elements = [
  ...nodes.map((n) => ({
    data: {
      id: n.id,
      label: ellipsise(n.label, labelMaxChars),
      fullLabel: n.label,
      weight: n.weight,
    },
  })),
  ...edges.map((e) => ({
    data: {
      id: `${e.source}-${e.target}`,
      source: e.source,
      target: e.target,
      weight: e.weight ?? 1,
      sharedTags: e.sharedTags ?? [],
    },
  })),
];
const json = JSON.stringify(elements);
---

{isEmpty ? (
  <div class="graph" style={`height:${height}px;display:flex;align-items:center;justify-content:center;`}>
    <p class="dim" style="text-align:center;max-width:24rem;">{emptyMessage}</p>
  </div>
) : (
  <div id={id} class="graph" style={`height:${height}px;`} data-elements={json}></div>
)}

<script>
  import cytoscape from 'cytoscape';

  function init() {
    document.querySelectorAll<HTMLElement>('.graph[data-elements]').forEach((el) => {
      if (el.dataset.initialized) return;
      el.dataset.initialized = '1';
      const raw = el.dataset.elements;
      if (!raw) return;
      const elements = JSON.parse(raw);
      const nodeCount = elements.filter((e: any) => !e.data.source).length;

      // Pick a layout that suits the data density.
      // - very small graphs (<= 8 nodes): even circle, predictable spacing
      // - medium graphs: cose, lets edges pull related nodes together
      // - large graphs (> 25 nodes): concentric, hubs in the center
      let layout: any;
      if (nodeCount <= 8) {
        layout = {
          name: 'circle',
          animate: false,
          padding: 80,
          spacingFactor: 1.4,
          radius: undefined,
        };
      } else if (nodeCount > 25) {
        layout = {
          name: 'concentric',
          animate: false,
          padding: 40,
          minNodeSpacing: 28,
          concentric: (n: any) => n.data('weight') || 1,
          levelWidth: () => 2,
          spacingFactor: 1.1,
        };
      } else {
        layout = {
          name: 'cose',
          animate: false,
          padding: 60,
          idealEdgeLength: () => 160,
          nodeRepulsion: () => 32000,
          gravity: 0.15,
          numIter: 1500,
          nodeOverlap: 40,
          componentSpacing: 100,
        };
      }

      const cy = cytoscape({
        container: el,
        elements,
        style: [
          {
            selector: 'node',
            style: {
              'background-color': '#1a1714',
              label: 'data(label)',
              color: '#3a322a',
              'font-family': 'Inter, sans-serif',
              'font-size': nodeCount <= 8 ? 16 : 14,
              'font-weight': 500,
              'text-margin-y': -12,
              'text-valign': 'top',
              'text-halign': 'center',
              'text-background-color': '#faf3e1',
              'text-background-opacity': 0.92,
              'text-background-padding': 4,
              'text-background-shape': 'roundrectangle',
              width: nodeCount <= 8 ? 16 : 'mapData(weight, 1, 8, 10, 32)',
              height: nodeCount <= 8 ? 16 : 'mapData(weight, 1, 8, 10, 32)',
              'border-width': 1,
              'border-color': '#d9c49e',
            },
          },
          {
            selector: 'node:active',
            style: {
              'overlay-color': '#a65e2e',
              'overlay-opacity': 0.2,
            },
          },
          {
            selector: 'edge',
            style: {
              width: 'mapData(weight, 1, 6, 1.2, 3)',
              'line-color': '#a65e2e',
              'curve-style': 'straight',
              opacity: 0.45,
              'font-family': 'Inter, sans-serif',
              'font-size': 14,
              'font-weight': 600,
              color: '#1a1714',
              'text-background-color': '#faf3e1',
              'text-background-opacity': 1,
              'text-background-padding': 8,
              'text-background-shape': 'roundrectangle',
              'text-border-color': '#a65e2e',
              'text-border-opacity': 0.6,
              'text-border-width': 1,
            },
          },
        ],
        layout,
        wheelSensitivity: 0.2,
        minZoom: 0.4,
        maxZoom: 2.5,
        userZoomingEnabled: false,
        userPanningEnabled: false,
      });

      // Keep the graph fitted as the container is sized.
      const fit = () => cy.fit(undefined, 40);
      fit();
      const ro = new ResizeObserver(fit);
      ro.observe(el);

      cy.on('mouseover', 'node', (e) => {
        e.target.style({
          'background-color': '#a65e2e',
          'border-color': '#a65e2e',
          color: '#1a1714',
          'font-weight': 600,
          label: e.target.data('fullLabel'),
          'z-index': 999,
        });
        el.style.cursor = 'pointer';
      });
      cy.on('mouseout', 'node', (e) => {
        e.target.removeStyle();
        el.style.cursor = '';
      });
      cy.on('tap', 'node', (e) => {
        const id = e.target.id();
        const link = document.querySelector<HTMLAnchorElement>(`a[data-paper-slug="${id}"]`);
        if (link?.href) window.location.href = link.href;
      });

      cy.on('mouseover', 'edge', (e) => {
        const tags = e.target.data('sharedTags') as string[] | undefined;
        if (!tags || tags.length === 0) return;
        e.target.style({
          label: tags.join('  ·  '),
          'line-color': '#7e441f',
          opacity: 0.9,
          'text-background-opacity': 1,
          'text-border-opacity': 1,
          width: 'mapData(weight, 1, 6, 2, 4)',
          'z-index': 998,
        });
      });
      cy.on('mouseout', 'edge', (e) => {
        e.target.removeStyle();
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
