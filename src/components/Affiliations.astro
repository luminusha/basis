---
import { u } from '../lib/url';
import { AFFILIATIONS } from '../lib/affiliations';

const logoFor = (a: typeof AFFILIATIONS[number]) =>
  a.logo ? u(a.logo) : '';
---

<section class="wrap-wide affiliations">
  <h2>Our members have worked with</h2>
  <ul>
    {AFFILIATIONS.map((a) => (
      <li>
        <a href={a.url} rel="noopener" title={a.name} aria-label={a.name}>
          {logoFor(a)
            ? <img src={logoFor(a)} alt="" loading="lazy" onerror="this.parentElement.classList.add('logo-fallback'); this.remove();" />
            : null}
          <span class="org-name">{a.name}</span>
        </a>
      </li>
    ))}
  </ul>
</section>

<style>
  .affiliations {
    margin-top: var(--space-6);
    padding-top: var(--space-4);
    border-top: 1px solid var(--rule);
    text-align: center;
  }
  .affiliations h2 {
    font-family: var(--font-serif);
    font-size: var(--step-1);
    font-style: italic;
    letter-spacing: 0.02em;
    color: var(--ink-mute);
    font-weight: 400;
    margin: 0 0 var(--space-4);
  }
  .affiliations ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: var(--space-4) var(--space-3);
    align-items: center;
    justify-items: center;
    max-width: 56rem;
    margin: 0 auto;
  }
  .affiliations li {
    margin: 0;
    width: 100%;
  }
  .affiliations a {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    gap: 0.55rem;
    min-height: 96px;
    padding: 0 var(--space-1);
    border: 0;
    color: var(--ink-mute);
    transition: transform 200ms ease, color 150ms ease;
  }
  .affiliations a:hover {
    transform: translateY(-2px);
    color: var(--ink);
  }
  .affiliations img {
    max-height: 56px;
    max-width: 100%;
    width: auto;
    height: auto;
    display: block;
    object-fit: contain;
  }
  .org-name {
    font-family: var(--font-sans);
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-faint);
    text-align: center;
    line-height: 1.3;
    margin-top: 0.1rem;
  }
  .affiliations a:hover .org-name {
    color: var(--ink-mute);
  }
  .affiliations .logo-fallback .org-name {
    font-family: var(--font-mark, var(--font-serif));
    font-size: 0.95rem;
    letter-spacing: 0.18em;
    color: var(--ink);
  }
</style>
