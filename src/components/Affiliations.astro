---
import { u } from '../lib/url';
import { AFFILIATIONS } from '../lib/affiliations';

const logoFor = (a: typeof AFFILIATIONS[number]) => {
  if (a.logo) return u(a.logo);
  if (a.clearbitDomain) return `https://logo.clearbit.com/${a.clearbitDomain}?size=200`;
  return '';
};
---

<section class="wrap-wide affiliations">
  <h2>
    Members are affiliated with
  </h2>
  <ul>
    {AFFILIATIONS.map((a) => (
      <li>
        <a href={a.url} rel="noopener" title={a.name} aria-label={a.name}>
          {logoFor(a)
            ? <img src={logoFor(a)} alt={a.name} loading="lazy" onerror="this.parentElement.classList.add('logo-fallback'); this.remove();" />
            : null}
          <span class="fallback-name">{a.name}</span>
        </a>
      </li>
    ))}
  </ul>
</section>

<style>
  .affiliations {
    margin-top: var(--space-5);
    text-align: center;
  }
  .affiliations h2 {
    font-family: var(--font-serif);
    font-size: var(--step-1);
    letter-spacing: 0.04em;
    color: var(--ink-mute);
    font-weight: 500;
    margin: 0 0 var(--space-3);
  }
  .affiliations ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: var(--space-4);
    row-gap: var(--space-3);
  }
  .affiliations li {
    margin: 0;
  }
  .affiliations a {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 56px;
    min-width: 80px;
    border: 0;
    color: var(--ink-mute);
    opacity: 0.7;
    transition: opacity 150ms ease, filter 150ms ease;
    filter: grayscale(1) contrast(0.85);
  }
  .affiliations a:hover {
    opacity: 1;
    filter: grayscale(0) contrast(1);
    color: var(--ink);
  }
  .affiliations img {
    max-height: 44px;
    max-width: 140px;
    width: auto;
    height: auto;
    display: block;
  }
  .fallback-name {
    display: none;
    font-family: var(--font-mark, var(--font-serif));
    font-size: 0.85rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    white-space: nowrap;
  }
  .affiliations .logo-fallback .fallback-name {
    display: inline;
  }
</style>
