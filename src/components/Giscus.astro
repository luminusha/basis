---
interface Props {
  term: string;
}
const { term } = Astro.props;
// Replace `repo`, `repoId`, `category`, `categoryId` with values from https://giscus.app
// once the GitHub repo + Discussions are set up.
---

<section class="giscus-wrap" style="margin-top:var(--space-5);">
  <h3 style="font-size:1.1rem;letter-spacing:0.05em;text-transform:uppercase;color:var(--ink-mute);font-weight:500;">Comments</h3>
  <p class="dim" style="font-size:0.9rem;margin-bottom:1rem;">
    Comments are powered by GitHub Discussions. Sign in with your GitHub account to add to the thread.
  </p>
  <script
    src="https://giscus.app/client.js"
    data-repo="luminusha/basis"
    data-repo-id="REPLACE_REPO_ID"
    data-category="Session Comments"
    data-category-id="REPLACE_CATEGORY_ID"
    data-mapping="specific"
    data-term={term}
    data-strict="1"
    data-reactions-enabled="1"
    data-emit-metadata="0"
    data-input-position="top"
    data-theme="light"
    data-lang="en"
    crossorigin="anonymous"
    async
  ></script>
</section>
